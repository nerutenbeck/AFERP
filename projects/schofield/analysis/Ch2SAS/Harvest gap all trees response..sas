/*creating a data set with dummy variables for tree type*/
Data HGtrees2; set HGtrees; 
Transrelratio=arsin(relratio);
Edgetree=1;
If Treetype=1 then Edgetree=1; else Edgetree=0;
Gapsapling=0;
If Treetype=0 then Gapsapling=1;else Gapsapling=0;

Proc Freq Data HGtrees2;
Tables (Edgetree Gapsapling)*Treetype/ norow nocol nopercent;
Title 'Frequency table to ensure dummy conditions are met for tree type';

Proc reg; 
Model Transrelratio=Treetype gapsize DBH;
Title 'Multiple regression on best tree type and DBH';

output out=A predicted=pred residual=resid;
Proc univariate plot normal;
var resid;
Title 'Normality test on best tree model with DBH';

Proc plot; Plot resid*pred;
Title 'Residual plot for regression model of best tree type with DBH';

Proc Reg; 
Model transrelratio= Treetype gapsize Height;
Title 'Multiple regression for best tree type response with height';

output out=B predicted=pred2 residual=resid2;
Proc univariate plot normal;
var resid2;
Title 'Nomrality test on regression model best tree with Height';

Proc plot; plot resid2*pred2;
Title 'Residual plot for regression model best tree with height';
run;
