Data Hgsaplings2;set HGsaplings;
If species= "ABIBAL" then TSUCAN=0;
If species= "TSUCAN" then TSUCAN=1;

Proc logistic descending;
Model relpct=TSUCAN gapsize dbh Tsucan*gapsize Tsucan*dbh 
gapsize*dbh Tsucan*gapsize*dbh/selection=backward slentry=0.05;
title1 'backward logistic regression HGSaps for pct release threshold';
 
Proc logistic descending;
Model relgrth=Tsucan gapsize dbh Tsucan*gapsize Tsucan*dbh
gapsize*dbh Tsucan*gapsize*dbh/selection=backward slentry=0.05;
Title 'backward logistic regression HGsaps for gap grwth threshold';

Proc logistic descending;
Model relboth=Tsucan gapsize dbh Tsucan*gapsize Tsucan*dbh
gapsize*dbh tsucan*gapsize*dbh/selection=backward slentry=0.05;
Title 'backward logistic regression HGsaps for both gap growth and pct resp';

