/*creating a data set with dummy variables*/
Data HGcores2; set HGcores;
If species="ACERUB" then do; TSUCAN=0; BETPAP=0;end;
If species="TSUCAN" then do; TSUCAN=1; BETPAP=0;end;
If species="BETPAP" then do; TSUCAN=0; BETPAP=1;end;
If strata= "A/B" then dom=1; else dom=0;
If strata= "C" then int=1; else int=0;
Proc print data=HGcores2;
var species TSUCAN BETPAP strata dom int;

/*Backward selection was chosen to look at full model with all interactions*/
/*eliminate effects that are insignificant to produce the best model*/
proc logistic descending;
model relpct=tsucan betpap gapsize dbh 
tsucan*betpap tsucan*gapsize tsucan*dbh 
betpap*gapsize betpap*dbh gapsize*dbh tsucan*betpap*gapsize
tsucan*betpap*dbh betpap*gapsize*dbh tsucan*gapsize*dbh
tsucan*betpap*gapsize*dbh/selection=backward
slentry=0.05 details;
Title1 'Backward logistic regression on harvest gap edge trees';
Title2 'Dependent variable-percent response release threshold';

